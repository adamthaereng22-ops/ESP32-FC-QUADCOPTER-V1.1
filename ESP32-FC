#include <Arduino.h>
#include <Wire.h>
#include <Adafruit_MPU6050.h>
#include <Adafruit_Sensor.h>
#include <Adafruit_BME280.h>
#include <ESP32Servo.h>
#include <TinyGPS++.h>
#include <math.h>

// pins - i changed these a lot
#define SDA_PIN 21
#define SCL_PIN 22

#define ESC1 13  // rear right
#define ESC2 14  // front right
#define ESC3 25  // rear left
#define ESC4 26  // front left

#define IBUS_RX 16
#define IBUS_TX 27
#define GPS_RX 17
#define GPS_TX 5

// esc limits
#define PWM_MIN 1000
#define PWM_IDLE 1050
#define PWM_MAX 2000

// objects
Adafruit_MPU6050 mpu;
Adafruit_BME280 bme;
Servo esc1, esc2, esc3, esc4;
HardwareSerial ibus(2);
HardwareSerial gpsSerial(1);
TinyGPSPlus gps;

// flags
bool armed = false;
uint32_t lastMotor = 0;

// angles and stuff
float roll = 0.0f, pitch = 0.0f;
float yawRate = 0.0f, yawAngle = 0.0f;
float alpha = 0.95f; // filter

// gyro calibration
float gxOff = 0, gyOff = 0, gzOff = 0;

// gyro lpf
float gxPrev = 0, gyPrev = 0, gzPrev = 0;
#define GYRO_LPF 0.43f

// bme
bool bmeOk = false;
float bmeT = 0, bmeP = 0, bmeAlt = 0, bmeAlt0 = 0;
#define SEA_PRESS 1013.25f

// pid struct
struct PID {
    float itg;
    float prev;
};

// angle pid
PID pidRoll, pidPitch;
float kpRoll = 1.2f, kiRoll = 0.0f, kdRoll = 0.0f;
float kpPitch = 1.2f, kiPitch = 0.0f, kdPitch = 0.0f;

// rate pid
PID pidRateR, pidRateP;
float kpRateR = 0.32f, kiRateR = 0.04f, kdRateR = 0.025f;
float kpRateP = 0.32f, kiRateP = 0.04f, kdRateP = 0.025f;

// yaw pid
PID pidYaw;
float kpYaw = 0.70f, kiYaw = 0.06f, kdYaw = 0.0f;

// gps hold pid
PID pidGpsX, pidGpsY;
float kpGps = 0.8f, kiGps = 0.02f, kdGps = 0.10f;
bool gpsHold = false;
double homeLat = 0, homeLon = 0;

// mixer vars
int throttleBase = PWM_IDLE;
int m1 = PWM_MIN, m2 = PWM_MIN, m3 = PWM_MIN, m4 = PWM_MIN;
float uR = 0, uP = 0, uY = 0;

// rc channels
#define CH_ROLL 0
#define CH_PITCH 1
#define CH_THR 2
#define CH_YAW 3
#define CH_ARM 4
#define CH_GPS 5

#define MAX_ANGLE 25.0f
#define MAX_RATE 250.0f
#define MAX_YAW 120.0f
#define DEAD 15
#define ARM_LIMIT 25.0f

uint16_t rc[14] = {1500,1500,1000,1500,1000};
uint32_t lastRc = 0;

// helpers
float mapf(float x, float i0, float i1, float o0, float o1) {
    return (x-i0)*(o1-o0)/(i1-i0)+o0;
}
float clampf(float v, float lo, float hi) {
    if(v<lo) return lo; if(v>hi) return hi; return v;
}
int dead(int v, int c=1500, int d=DEAD) {
    return abs(v-c)<=d ? c : v;
}

// pid compute
float pidCalc(float sp, float meas, PID &s, float dt, float kp, float ki, float kd, float minOut, float maxOut) {
    float err = sp - meas;
    float d = (meas - s.prev) / dt;
    s.prev = meas;
    s.itg += err * dt;
    s.itg = clampf(s.itg, -80.0f, 80.0f);
    float out = kp*err + ki*s.itg - kd*d;
    return clampf(out, minOut, maxOut);
}

// imu update
void getIMU(float dt) {
    sensors_event_t a, g, t;
    mpu.getEvent(&a, &g, &t);
    float gx = (g.gyro.x - gxOff) * 57.29578f;
    float gy = (g.gyro.y - gyOff) * 57.29578f;
    float gz = (g.gyro.z - gzOff) * 57.29578f;
    // lpf
    gx = gxPrev*GYRO_LPF + gx*(1-GYRO_LPF); gxPrev=gx;
    gy = gyPrev*GYRO_LPF + gy*(1-GYRO_LPF); gyPrev=gy;
    gz = gzPrev*GYRO_LPF + gz*(1-GYRO_LPF); gzPrev=gz;
    // integrate
    roll += gx * dt;
    pitch += gy * dt;
    yawAngle += gz * dt;
    yawRate = gz;
    // accel angles
    float aRoll = atan2f(a.acceleration.y, a.acceleration.z) * 57.29578f;
    float aPitch = atan2f(-a.acceleration.x, sqrtf(a.acceleration.y*a.acceleration.y + a.acceleration.z*a.acceleration.z)) * 57.29578f;
    // complementary
    roll = alpha*roll + (1-alpha)*aRoll;
    pitch = alpha*pitch + (1-alpha)*aPitch;
}

// mix motors
void mix() {
    m1 = throttleBase - uR - uP + uY;
    m2 = throttleBase - uR + uP - uY;
    m3 = throttleBase + uR - uP - uY;
    m4 = throttleBase + uR + uP + uY;
}

// read ibus
bool readIbus() {
    if(ibus.available() < 32) return false;
    if(ibus.peek() != 0x20) { ibus.read(); return false; }
    uint8_t buf[32];
    ibus.readBytes(buf, 32);
    if(buf[0]!=0x20 || buf[1]!=0x40) return false;
    uint16_t sum=0;
    for(int i=0;i<30;i++) sum+=buf[i];
    if((0xFFFF-sum) != ((uint16_t)buf[30] | ((uint16_t)buf[31]<<8))) return false;
    for(int ch=0;ch<14;ch++) {
        int idx=2+ch*2;
        rc[ch] = (uint16_t)buf[idx] | ((uint16_t)buf[idx+1]<<8);
    }
    lastRc = millis();
    return true;
}
uint16_t getRc(int ch) { return (ch<0||ch>=14)?1500:rc[ch]; }

void setup() {
    Serial.begin(115200);
    delay(500);
    Serial.println("boot...");
    Wire.begin(SDA_PIN, SCL_PIN);

    // mpu
    if(!mpu.begin()) { while(1) Serial.println("mpu fail"); }
    mpu.setAccelerometerRange(MPU6050_RANGE_4_G);
    mpu.setGyroRange(MPU6050_RANGE_500_DEG);
    mpu.setFilterBandwidth(MPU6050_BAND_44_HZ);
    // calibrate gyro
    Serial.println("cal gyro...");
    float sx=0,sy=0,sz=0;
    for(int i=0;i<4000;i++) {
        sensors_event_t a,g,t;
        mpu.getEvent(&a,&g,&t);
        sx+=g.gyro.x; sy+=g.gyro.y; sz+=g.gyro.z;
        delay(1);
    }
    gxOff = sx/4000.0f; gyOff = sy/4000.0f; gzOff = sz/4000.0f;

    // ibus
    ibus.begin(115200, SERIAL_8N1, IBUS_RX, IBUS_TX);
    ibus.setTimeout(1);

    // escs
    ESP32PWM::allocateTimer(0); ESP32PWM::allocateTimer(1);
    ESP32PWM::allocateTimer(2); ESP32PWM::allocateTimer(3);
    esc1.setPeriodHertz(50); esc2.setPeriodHertz(50);
    esc3.setPeriodHertz(50); esc4.setPeriodHertz(50);
    esc1.attach(ESC1, PWM_MIN, PWM_MAX);
    esc2.attach(ESC2, PWM_MIN, PWM_MAX);
    esc3.attach(ESC3, PWM_MIN, PWM_MAX);
    esc4.attach(ESC4, PWM_MIN, PWM_MAX);
    esc1.writeMicroseconds(PWM_MIN);
    esc2.writeMicroseconds(PWM_MIN);
    esc3.writeMicroseconds(PWM_MIN);
    esc4.writeMicroseconds(PWM_MIN);

    // bme
    if(bme.begin(0x76) || bme.begin(0x77)) {
        bmeOk = true;
        delay(100);
        bmeAlt0 = bme.readAltitude(SEA_PRESS);
        Serial.println("bme ok");
    } else Serial.println("no bme");

    // gps
    gpsSerial.begin(9600, SERIAL_8N1, GPS_RX, GPS_TX);

    Serial.println("ready. remove props!");
}

void loop() {
    static uint32_t lastLoop = micros();
    uint32_t now = micros();
    if(now - lastLoop < 500) return;
    float dt = (now - lastLoop) * 1e-6f;
    lastLoop = now;

    getIMU(dt);
    while(readIbus()) {}

    uint16_t thr = getRc(CH_THR);
    uint16_t ail = dead(getRc(CH_ROLL));
    uint16_t ele = dead(getRc(CH_PITCH));
    uint16_t rud = dead(getRc(CH_YAW));
    uint16_t armSw = getRc(CH_ARM);
    uint16_t gpsSw = getRc(CH_GPS);

    bool wantArm = (armSw > 1700);
    bool thrLow = (thr < PWM_IDLE);
    gpsHold = (gpsSw > 1700);

    static float yawOffset = yawAngle;

    // arming
    if(wantArm && !armed && thrLow && fabs(roll)<=ARM_LIMIT && fabs(pitch)<=ARM_LIMIT) {
        armed = true;
        yawOffset = yawAngle;
        if(gps.location.isValid()) { homeLat = gps.location.lat(); homeLon = gps.location.lng(); }
        for(int us=PWM_MIN; us<=PWM_IDLE; us+=5) {
            esc1.writeMicroseconds(us); esc2.writeMicroseconds(us);
            esc3.writeMicroseconds(us); esc4.writeMicroseconds(us);
            delay(3);
        }
        pidRoll.itg=pidPitch.itg=0; pidRateR.itg=pidRateP.itg=0;
        pidYaw.itg=0; pidGpsX.itg=pidGpsY.itg=0;
    } else if(!wantArm && armed) {
        armed = false;
        esc1.writeMicroseconds(PWM_MIN); esc2.writeMicroseconds(PWM_MIN);
        esc3.writeMicroseconds(PWM_MIN); esc4.writeMicroseconds(PWM_MIN);
    }

    throttleBase = clampf(thr, PWM_MIN, PWM_MAX);

    // gps data
    while(gpsSerial.available()) gps.encode(gpsSerial.read());
    static double lastLat=0, lastLon=0;
    if(gps.location.isValid()) { lastLat = gps.location.lat(); lastLon = gps.location.lng(); }

    float gpsR=0, gpsP=0;
    if(gpsHold) {
        double dLat = (lastLat - homeLat)*111320.0;
        double dLon = (lastLon - homeLon)*111320.0*cos(homeLat*DEG_TO_RAD);
        gpsP = pidCalc(0.0f, dLat, pidGpsX, dt*0.5f, kpGps, kiGps, kdGps, -10,10);
        gpsR = pidCalc(0.0f, dLon, pidGpsY, dt*0.5f, kpGps, kiGps, kdGps, -10,10);
    }

    float spRoll = mapf(ail,1000,2000,-MAX_ANGLE,MAX_ANGLE) + gpsR;
    float spPitch = mapf(ele,1000,2000,-MAX_ANGLE,MAX_ANGLE) + gpsP;
    float spYawRate = mapf(rud,1000,2000,-MAX_YAW,MAX_YAW);

    // angle to rate
    float rateTargetR = pidCalc(spRoll, roll, pidRoll, dt, kpRoll, kiRoll, kdRoll, -MAX_RATE, MAX_RATE);
    float rateTargetP = pidCalc(spPitch, pitch, pidPitch, dt, kpPitch, kiPitch, kdPitch, -MAX_RATE, MAX_RATE);

    // rate to motor
    uR = pidCalc(rateTargetR, gxPrev, pidRateR, dt, kpRateR, kiRateR, kdRateR, -150,150);
    uP = -pidCalc(rateTargetP, gyPrev, pidRateP, dt, kpRateP, kiRateP, kdRateP, -150,150);

    // yaw
    float yawErr = yawAngle - yawOffset;
    float yawSp = spYawRate - yawErr;
    uY = pidCalc(yawSp, yawRate, pidYaw, dt, kpYaw, kiYaw, kdYaw, -120,120);

    mix();

    // slew rate
    const int SLEW = 8;
    auto slewLim = [&](int t, int &c) { int d=t-c; if(d>SLEW) d=SLEW; if(d<-SLEW) d=-SLEW; c+=d; };
    slewLim(m1,m1); slewLim(m2,m2); slewLim(m3,m3); slewLim(m4,m4);

    if(micros()-lastMotor >= 1000) {
        lastMotor = micros();
        if(armed) {
            esc1.writeMicroseconds(m1<PWM_IDLE?PWM_IDLE:m1);
            esc2.writeMicroseconds(m2<PWM_IDLE?PWM_IDLE:m2);
            esc3.writeMicroseconds(m3<PWM_IDLE?PWM_IDLE:m3);
            esc4.writeMicroseconds(m4<PWM_IDLE?PWM_IDLE:m4);
        } else {
            esc1.writeMicroseconds(PWM_MIN); esc2.writeMicroseconds(PWM_MIN);
            esc3.writeMicroseconds(PWM_MIN); esc4.writeMicroseconds(PWM_MIN);
        }
    }

    // bme read
    if(bmeOk) {
        bmeT = bme.readTemperature();
        bmeP = bme.readPressure()/100.0f;
        bmeAlt = bme.readAltitude(SEA_PRESS) - bmeAlt0;
    }

    // debug print
    static uint32_t lastPrint=0;
    if(millis()-lastPrint>=80) {
        lastPrint=millis();
        Serial.print(armed?"ARM ":"DIS ");
        Serial.print("T:"); Serial.print(throttleBase);
        Serial.print(" R/P/Y:"); Serial.print(roll,1); Serial.print("/"); Serial.print(pitch,1); Serial.print("/"); Serial.print(yawAngle,1);
        Serial.print(" U:"); Serial.print((int)uR); Serial.print(","); Serial.print((int)uP); Serial.print(","); Serial.print((int)uY);
        Serial.print(" M:"); Serial.print(m1); Serial.print(","); Serial.print(m2); Serial.print(","); Serial.print(m3); Serial.print(","); Serial.print(m4);
        if(bmeOk) { Serial.print(" Tmp:"); Serial.print(bmeT,1); Serial.print(" Alt:"); Serial.print(bmeAlt,1); }
        if(gps.location.isUpdated()) { Serial.print(" GPS:"); Serial.print(gps.location.lat(),6); Serial.print("/"); Serial.print(gps.location.lng(),6); }
        Serial.println();
    }
}
